{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/typed-claude-hooks/preToolUse-blockDangerous.sh",
            "__managed": "typed-claude-hooks"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/typed-claude-hooks/stop-onStop.sh",
            "__managed": "typed-claude-hooks"
          }
        ]
      }
    ]
  }
}
