{
  "name": "clauptain-hook",
  "version": "0.1.0",
  "description": "Type-safe Claude Code hooks in TypeScript",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "clauptain-hook": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "extract-types": "tsx scripts/extract-types.ts",
    "generate-monaco-dts": "tsx scripts/generate-monaco-dts.ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "hooks",
    "typescript",
    "claude-code"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^13.0.0",
    "esbuild": "^0.25.0"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.0",
    "prettier": "^3.8.4",
    "ts-morph": "^28.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
