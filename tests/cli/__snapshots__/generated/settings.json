{
  "model": "claude-sonnet-4-6",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "hooks/typed-claude-hooks/preToolUse-blockDangerous.cjs"
            ],
            "__managed": "typed-claude-hooks"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "hooks/typed-claude-hooks/stop-onStop.cjs"
            ],
            "__managed": "typed-claude-hooks"
          }
        ]
      }
    ]
  }
}
